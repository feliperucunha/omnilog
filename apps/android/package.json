{
  "name": "@dogument/android",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "sync": "cap sync",
    "sync:android": "cap sync android",
    "sync:ios": "cap sync ios",
    "open": "cap open android",
    "open:ios": "cap open ios",
    "build": "pnpm --filter @dogument/web build:android && cap sync",
    "android": "pnpm --filter @dogument/web build:android && cap sync android && cap open android",
    "ios": "pnpm --filter @dogument/web build:android && cap sync ios && cap open ios"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@capacitor/android": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0"
  },
  "capacitor": {
    "platforms": ["android", "ios"]
  }
}
