# -----------------------------------------------------------------------------
# Backend (API) – copy to .env and fill in. For production, use your host’s env.
# -----------------------------------------------------------------------------

# Database – Supabase (free tier): Project Settings → Database → Connection string (URI)
# Pooler (port 6543, Transaction): use for runtime. For "prisma migrate" use Session/direct (port 5432) if needed.
# IMPORTANT: When using the Transaction pooler (port 6543), append ?pgbouncer=true to DATABASE_URL
# (if the URL already has query params, use &pgbouncer=true). This avoids "prepared statement does not exist" errors.
# Example (Supabase pooler): postgresql://USER:PASSWORD@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=

# Auth – generate a long random string (min 32 chars). Never commit the real secret.
JWT_SECRET=
# Optional: name of the httpOnly auth cookie (default: auth). Set NODE_ENV=production on
# Render/Vercel so the cookie uses Secure and SameSite=None for cross-origin.
# AUTH_COOKIE_NAME=auth

# Server
PORT=3001

# Rate limit: max requests per 15 min (default 1500). Batch import uses ~2 requests per row (search + create).
# Increase if you see 429 when importing large files or doing heavy use.
# RATE_LIMIT_MAX=1500
# RATE_LIMIT_WINDOW_MS=900000

# Deployed frontend URL (for CORS and auth redirect/reset links).
# Local: http://localhost:5173
WEB_ORIGIN="http://localhost:5173"
# Production: set to your Vercel (or other) frontend URL. Must match exactly (no trailing slash).
# The browser only stores the auth cookie from login if CORS returns this exact origin.
# If wrong, you get "logged in" then immediately redirected back to login.
# WEB_ORIGIN="https://your-app.vercel.app"

# Optional: comma-separated list of allowed CORS origins (frontend URLs only — where the
# browser runs; do not put the API URL here). Use in production to allow both the
# deployed app and localhost (e.g. when developing against the deployed API).
# Each origin must match exactly (no trailing slash). API must be served over HTTPS.
# Example: CORS_ORIGINS="https://your-app.vercel.app,http://localhost:5173,http://127.0.0.1:5173"
# Android (Capacitor) app sends Origin "http://localhost" — add it if not using CapacitorHttp:
# CORS_ORIGINS="https://your-app.vercel.app,http://localhost"
# CORS_ORIGINS=

# -----------------------------------------------------------------------------
# External API keys (optional; users can add their own in-app)
# -----------------------------------------------------------------------------
# TMDB: https://www.themoviedb.org/settings/api (Movies & TV)
# TMDB_API_KEY=
# RAWG: https://rawg.io/apidocs (Games)
# RAWG_API_KEY=
# BGG: https://boardgamegeek.com/applications (Board games)
# BGG_API_TOKEN=
# Comic Vine: https://comicvine.gamespot.com/api/ (Comics)
# COMIC_VINE_API_KEY=

# -----------------------------------------------------------------------------
# Password reset email (optional; if unset, reset link is logged to console)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Geeklogs <noreply@example.com>

# -----------------------------------------------------------------------------
# Stripe (Pro subscriptions)
# -----------------------------------------------------------------------------
# Create products and recurring prices in Stripe Dashboard. Recommended:
# - Default: $5/month, $50/year (USD)
# - Brazil: R$ 20/month, R$ 200/year (BRL)
# Then set the Price IDs below. Webhook: Stripe Dashboard → Developers → Webhooks
# → Add endpoint → /api/stripe/webhook → select checkout.session.completed,
# customer.subscription.updated, customer.subscription.deleted.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=
STRIPE_PRICE_ID_BR_MONTHLY=
STRIPE_PRICE_ID_BR_YEARLY=

# -----------------------------------------------------------------------------
# Subscription expiry (runs in-process on startup and every 24h – no external cron needed)
# -----------------------------------------------------------------------------
# Optional: set CRON_SECRET to allow manual trigger via GET /api/cron/subscriptions?secret=...
# Pro users with subscriptionEndsAt = null are never expired (endless Pro, for testing).
# CRON_SECRET=
