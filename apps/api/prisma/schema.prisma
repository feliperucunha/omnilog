generator client {
  provider = "prisma-client-js"
}

// When using a transaction-mode pooler (e.g. Supabase pooler :6543, PgBouncer),
// add ?pgbouncer=true to DATABASE_URL (or &pgbouncer=true if URL has other params).
// Otherwise you get: "prepared statement \"s20\" does not exist" in production.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Tier {
  free
  pro
  admin
}

enum BadgeMedium {
  MOVIE
  TV_SHOW
  ANIME
  MANGA
  COMIC
  BOOK
  GAME
  BOARD_GAME
}

enum BadgeRarity {
  common
  rare
  epic
  legendary
}

enum BadgeConditionType {
  FIRST_REVIEW
  REVIEW_COUNT_PER_MEDIA
  REVIEW_COUNT_GLOBAL
  MEDIA_TYPES_REVIEWED
  REVIEW_LIKES
  REVIEW_STREAK
  LOG_COUNT_PER_MEDIA
  LOG_COUNT_GLOBAL
  LOG_MEDIA_TYPES_LOGGED
}

model User {
  id                   String    @id @default(cuid())
  username             String?   @unique
  email                String    @unique
  password             String
  passwordResetToken   String?   // unique token for reset link
  passwordResetExpires DateTime? // token expiry (e.g. 1h)
  tmdbApiKey       String?
  rawgApiKey       String?
  bggApiToken        String?
  ludopediaApiToken  String?
  comicVineApiKey    String?
  preferredTheme       String?  // "light" | "dark"
  preferredLocale      String?  // "en" | "pt-BR" | "es"
  visibleMediaTypes    String?  // JSON array of media type strings; null = all
  boardGameProvider   String?  // "bgg" | "ludopedia"; null = bgg
  tier                Tier     @default(free)
  stripeSubscriptionId  String?  @unique // Stripe subscription ID for Pro
  stripeCustomerId     String?  // Stripe customer ID (for billing portal)
  subscriptionEndsAt   DateTime?       // Pro access until this date; cron clears tier when past; null = endless (e.g. testing)
  country             String?  // ISO 3166-1 alpha-2 e.g. BR for pricing
  onboarded           Boolean  @default(false)
  currentStreak       Int      @default(0)
  lastReviewDate      DateTime?
  selectedBadgeIds    String?  // JSON array of up to 3 badge IDs for profile display
  loginCount          Int      @default(0)  // number of times the user has logged in
  lastLoginAt         DateTime?            // last login timestamp
  createdAt           DateTime @default(now())
  updatedAt      DateTime @updatedAt
  logs          Log[]
  logReactions  LogReaction[]
  feedbacks      Feedback[]
  followsFollowing  Follow[] @relation("FollowFollowing")
  followsFollowers  Follow[] @relation("FollowFollower")
  userBadges     UserBadge[]
  reviewStats    UserReviewStats?
}

model Badge {
  id              String             @id @default(cuid())
  name            String
  description     String
  icon            String
  medium          BadgeMedium?
  rarity          BadgeRarity        @default(common)
  conditionType   BadgeConditionType
  conditionValue  Int
  hidden          Boolean            @default(false)
  createdAt       DateTime           @default(now())
  userBadges      UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

model Milestone {
  id        String       @id @default(cuid())
  metric    String       // "reviews" | "logs"
  scope     String       // "global" | "per_medium"
  medium    BadgeMedium? // null when scope = global
  threshold Int
  label     String
  icon      String
  sortOrder Int          @default(0) // for stable ordering

  @@unique([metric, scope, medium, threshold])
  @@index([metric, scope])
}

model UserReviewStats {
  userId                 String   @id
  movieReviews           Int      @default(0)
  tvShowReviews          Int      @default(0)
  animeReviews           Int      @default(0)
  mangaReviews           Int      @default(0)
  comicReviews           Int      @default(0)
  bookReviews            Int      @default(0)
  gameReviews            Int      @default(0)
  boardGameReviews       Int      @default(0)
  totalReviews           Int      @default(0)
  distinctMediaReviewed  Int      @default(0)
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("FollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("FollowFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int      // 1-10
  comments  String?  // optional text
  createdAt DateTime @default(now())

  @@index([userId])
}

model Log {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaType  String
  externalId String
  title      String
  image      String?  // poster/cover URL saved when logging (for cards and item page fallback)
  grade      Int?     // null when only in list without review
  review     String?  // optional comment (sanitized before save)
  listType   String?  // legacy "favorites" | "pending"
  status       String?   // per-media: watched, completed, playing, etc.
  startedAt    DateTime? // when set to in-progress (watching/reading/playing)
  completedAt  DateTime? // when set to completed
  contentHours Float?   // duration of content in hours (for stats)
  hoursToBeat  Float?  // games only: how long it took the user to beat (hours)
  season       Int?     // tv, anime
  episode      Int?     // tv, anime
  chapter      Int?     // anime, manga, comics
  volume       Int?     // anime, manga, comics
  boardGameSource String?  // "bgg" | "ludopedia" when mediaType = boardgames; which API this externalId came from
  genres         String?  // JSON array of genre names (for stats and badges)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  reactions   LogReaction[]

  @@unique([userId, mediaType, externalId])
  @@index([userId])
  @@index([userId, mediaType])
  @@index([mediaType, externalId])
}

model LogReaction {
  id        String   @id @default(cuid())
  logId     String
  userId    String
  type      String   // "like" | "dislike"
  createdAt DateTime @default(now())
  log       Log      @relation(fields: [logId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, logId])
  @@index([logId])
  @@index([userId])
}
